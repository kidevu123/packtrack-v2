# Copy to /etc/packtrack/packtrack.env on the LXC; do NOT commit a real .env.
PACKTRACK_SECRET_KEY=replace-with-openssl-rand-hex-32
DATABASE_URL=postgresql+psycopg://packtrack:CHANGE_ME@127.0.0.1:5432/packtrack
APP_BASE_URL=http://192.168.1.206
UPLOAD_DIR=/opt/packtrack/uploads
LOG_DIR=/var/log/packtrack

# Zoho Inventory — get from Zoho API console
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REFRESH_TOKEN=
ZOHO_ORG_ID=
ZOHO_TOKEN_URL=https://accounts.zoho.com/oauth/v2/token
ZOHO_API_BASE=https://www.zohoapis.com/inventory/v1

# Telegram bot (optional but recommended)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# zoho-integration-service — Pack Track receive write path. Pack Track must
# not hold Zoho credentials or call Zoho directly for purchase receives.
# Configure on the deploy host; never bake values into code.
ZOHO_INTEGRATION_BASE_URL=
ZOHO_INTEGRATION_APP_TOKEN=
ZOHO_INTEGRATION_BRAND=
ZOHO_INTEGRATION_TIMEOUT_SECONDS=30
ZOHO_INTEGRATION_RECEIVE_ENABLED=true
